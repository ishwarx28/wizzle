{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "clipboard-manager:default",
    "dialog:default",
    "notification:default",
    "opener:default",
    {
      "identifier": "opener:allow-open-path",
      "allow": [
        {
          "path": "$HOME/**",
          "app": null
        },
        {
          "path": "$TEMP/**",
          "app": null
        }
      ]
    }
  ]
}
