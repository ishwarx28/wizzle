# Agent loop limits.
VITE_WIZZLE_MAX_AGENT_STEPS=100
VITE_WIZZLE_MAX_PROMPT_SIZE=20480
WIZZLE_COMPACTED_CONTEXT_TOKENS=5120
WIZZLE_OUTPUT_RESERVED_PERCENT=10
WIZZLE_HEALTHY_CONTEXT_PERCENT=30

# Frontend and desktop logs are local only.
VITE_WIZZLE_FRONTEND_LOG_MODE=debug
VITE_WIZZLE_FRONTEND_LOG_RETENTION_DAYS=7
WIZZLE_DESKTOP_LOG_MODE=debug
WIZZLE_DESKTOP_LOG_RETENTION_DAYS=7

# Static About details and the email-only feedback destination.
VITE_WIZZLE_CONTACT_NAME=Ishwar Meghwal
VITE_WIZZLE_CONTACT_EMAIL=mrdev.288@gmail.com
VITE_WIZZLE_CONTACT_GITHUB_URL=https://github.com/ishwarx28
VITE_WIZZLE_CONTACT_LINKEDIN_URL=https://www.linkedin.com/in/ishwar-meghwal/
VITE_WIZZLE_APP_VERSION=0.1.0

# Initial provider import. The file is loaded only when no provider import has been recorded.
WIZZLE_PROVIDERS_YAML_PATH=../opencode-models.yaml

# Optional local override for provider API-key encryption.
WIZZLE_PROVIDER_KEY=
