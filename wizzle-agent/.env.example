# Agent loop limits.
VITE_WIZZLE_MAX_AGENT_STEPS=100
VITE_WIZZLE_MAX_PROMPT_SIZE=20480
WIZZLE_COMPACTED_CONTEXT_TOKENS=5120
WIZZLE_OUTPUT_RESERVED_PERCENT=10
WIZZLE_CONTEXT_SAFETY_PERCENT=5
WIZZLE_COMPACTION_TRIGGER_PERCENT=80
WIZZLE_POST_COMPACTION_TARGET_PERCENT=60
WIZZLE_ACTIVE_TURN_PRESSURE_PERCENT=90

# Frontend and desktop logs are local only.
VITE_WIZZLE_FRONTEND_LOG_MODE=debug
VITE_WIZZLE_FRONTEND_LOG_RETENTION_DAYS=7
WIZZLE_DESKTOP_LOG_MODE=debug
WIZZLE_DESKTOP_LOG_RETENTION_DAYS=7

# Required public manifest containing developer metadata, updates, prompts, and provider catalog URLs.
WIZZLE_CONFIG_URL=https://raw.githubusercontent.com/ishwarx28/wizzle/main/remote-config/app-config.yaml
